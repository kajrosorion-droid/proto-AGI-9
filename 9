def match_patterns(new_components, old_patterns, field, t=None):
    global next_pattern_id
    matched = set()
    updated_patterns = []
    alive = [p for p in old_patterns if p.alive]
    normal_count = len([p for p in alive if p.role_type == "normal"])
    for cells in new_components:
        best_p = None
        best_overlap = 0
        for p in old_patterns:
            if not p.alive or p.id in matched:
                continue
            overlap = len(cells & p.cells)
            if overlap > best_overlap:
                best_overlap = overlap
                best_p = p
        if best_p and best_overlap > len(cells) * 0.3:
            best_p.cells = cells
            best_p.update_properties(field)
            best_p.update_model(field, t=t)
            best_p.age += 1
            updated_patterns.append(best_p)
            matched.add(best_p.id)
        else:
            if normal_count < Config.OVERPOPULATION_CAP:
                pid = next_pattern_id
                next_pattern_id += 1
                p = Pattern(pid, cells)
                p.update_properties(field)
                p.update_model(field, t=t)
                updated_patterns.append(p)
                normal_count += 1
    for p in old_patterns:
        if p.alive and p.id not in matched:
            if p.role_type == "normal" and p.age < 20 and len(p.cells) == 0:
                p.alive = False
    for p in old_patterns:
        if p.alive and p.id not in matched:
            updated_patterns.append(p)
    return updated_patterns

def detect_new_components(field, min_cells=None):
    if min_cells is None:
        min_cells = Config.MIN_COMPONENT_CELLS
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    mask = energy > Config.PATTERN_ENERGY_THRESHOLD
    labeled, num = label(mask)
    slices = find_objects(labeled)
    components = []
    for i, slc in enumerate(slices, 1):
        if slc is None:
            continue
        region = labeled[slc] == i
        coords = np.argwhere(region)
        if len(coords) < min_cells:
            continue
        cells = {(slc[0].start + c[0], slc[1].start + c[1]) for c in coords}
        components.append(cells)
    return components

def ecosystem_pressure(field):
    energy = np.nan_to_num(field[:,:,CH['energy']], nan=0.0)
    avg = np.mean(energy)
    field[:,:,CH['energy']] += 0.002 * (avg - energy)
    field[:,:,CH['flux']] += 0.001 * (np.roll(energy, 1, axis=0) - energy) + 0.001 * (np.roll(energy, -1, axis=1) - energy)
    return field

