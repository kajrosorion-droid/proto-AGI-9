def resolve_competitions_spatial(patterns, field, max_dist=None):
    if max_dist is None:
        max_dist = Config.COMPETITION_MAX_DISTANCE
    alive = [p for p in patterns if p.alive and p.cells]
    if len(alive) < 2:
        return
    cell_size = max(1, max_dist)
    spatial_map = {}
    for p in alive:
        cx = sum(c[0] for c in p.cells) // len(p.cells)
        cy = sum(c[1] for c in p.cells) // len(p.cells)
        key = (cx // cell_size, cy // cell_size)
        spatial_map.setdefault(key, []).append(p)   # исправлено с setdefault на setdefault
    checked_pairs = set()
    for (gx, gy), group in spatial_map.items():
        for dx in [-1, 0, 1]:
            for dy in [-1, 0, 1]:
                neighbor_key = (gx + dx, gy + dy)
                if neighbor_key not in spatial_map:
                    continue
                others = spatial_map[neighbor_key]
                for p1 in group:
                    for p2 in others:
                        if p1.id >= p2.id:
                            continue
                        pair = (p1.id, p2.id)
                        if pair in checked_pairs:
                            continue
                        if not p1.cells & p2.cells:
                            continue
                        checked_pairs.add(pair)
                        p1.compete(p2, field)

def process_spores(patterns, field):
    global next_pattern_id
    new_patterns = []
    alive = [p for p in patterns if p.alive]
    normal_count = len([p for p in alive if p.role_type == "normal"])
    for p in patterns:
        if p.alive and p.pending_spore and p.pending_spore['x'] is not None:
            if normal_count >= Config.OVERPOPULATION_CAP:
                p.pending_spore = None
                continue
            spore = p.pending_spore
            if field[spore['x'], spore['y'], CH['owner']] != 0:
                p.pending_spore = None
                continue
            pid = next_pattern_id
            next_pattern_id += 1
            cells = {(spore['x'], spore['y'])}
            child = Pattern(pid, cells, parent=p)
            child.scar_dream = spore['scar_dream']
            child.update_properties(field)
            child.update_model(field)
            new_patterns.append(child)
            field[spore['x'], spore['y'], CH['owner']] = child.id
            p.pending_spore = None
            normal_count += 1
    return patterns + new_patterns

