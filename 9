class LayerZeroManager:
    def __init__(self):
        self.operator_scar = 0.0
        self.proto_signals = np.zeros(6)
        self.last_echo_injection = -100
        self.last_rescue_t = -100
        self.last_emergency_diversification_t = -1000

    def apply_operator_influence(self, field, patterns):
        avg_err = safe_mean([p.pred_error for p in patterns if p.alive], 0.1)
        avg_soul = safe_mean([p.soul_weight for p in patterns if p.alive], 0.5)
        for ch_idx in range(CH['signal_alarm'], CH['signal_grief']+1):
            field[:,:,ch_idx] *= Config.OPERATOR_SIGNAL_DECAY
        for p in patterns:
            if not p.alive: continue
            irreversible = p.crisis_memory * 0.5
            self.operator_scar = Config.OPERATOR_MEMORY_DECAY * self.operator_scar + (1 - Config.OPERATOR_MEMORY_DECAY) * irreversible
            for (x,y) in p.cells:
                field[x,y,CH['signal_curiosity']] += Config.OPERATOR_SIGNAL_STRENGTH * (1.0 - avg_err)
                field[x,y,CH['signal_warning']] += Config.OPERATOR_SIGNAL_STRENGTH * avg_err
                field[x,y,CH['signal_invitation']] += Config.OPERATOR_SIGNAL_STRENGTH * (1.0 - avg_soul)
                field[x,y,CH['signal_alarm']] += Config.OPERATOR_SIGNAL_STRENGTH * self.operator_scar
        for ch_idx in range(CH['signal_alarm'], CH['signal_grief']+1):
            self.proto_signals[ch_idx - CH['signal_alarm']] = safe_mean(field[:,:,ch_idx], 0)
        field[:,:,CH['unknown']] *= Config.UNKNOWN_DECAY
        field[:,:,CH['unknown']] += Config.UNKNOWN_BACKGROUND * (1.0 - Config.UNKNOWN_DECAY)
        field[:,:,CH['binding']] *= 0.98
        field[:,:,CH['binding']] = np.maximum(field[:,:,CH['binding']], Config.BINDING_FLOOR)
        field[:,:,CH['surprise']] *= Config.SURPRISE_DECAY
        field[:,:,CH['signal_grief']] = np.clip(field[:,:,CH['signal_grief']], 0, Config.MAX_GRIEF_SIGNAL)

    def crisis_injection(self, field, t):
        if t % Config.CRISIS_PERIOD == 0 and t > 0:
            intensity = Config.CRISIS_INTENSITY * (1.0 + 0.5 * np.sin(t * 0.01))
            for x in range(Config.WORLD_SIZE):
                for y in range(Config.WORLD_SIZE):
                    if phi_hash(x, y, t) < intensity:
                        field[x, y, CH['energy']] += (phi_hash(x, y, t+1) - 0.5) * 0.2
                        field[x, y, CH['unknown']] = min(0.8, field[x, y, CH['unknown']] + 0.15)
                        field[x, y, CH['crisis']] = min(1.0, field[x, y, CH['crisis']] + 0.3)

    def anti_conformist_injection(self, patterns, t):
        if t % Config.ANTI_CONFORMIST_INTERVAL != 0 or t == 0: return
        alive = [p for p in patterns if p.alive and p.age >= Config.MIN_AGE_FOR_ANTI_CONFORMIST]
        if not alive: return
        mutant_index = int(phi_hash(t, 0, 777) * len(alive))
        mutant = alive[mutant_index]
        mutant.emotional_memory['gratitude'] = 0.1
        mutant.emotional_memory['grief'] = 0.1
        mutant.semantic_state = "neutral"
        mutant.intent = None
        mutant.intent_commitment = 0.0
        mutant.goals = [{"type":"explore", "priority":1.5, "target":None, "age":0, "persistence":40}]
        mutant.last_intent_switch_age = mutant.age
        mutant._log_event("anti_conformist_injected", t=t)
        if t % 200 == 0: print(f"[t={t}] ANTI-CONFORMIST: Pattern {mutant.id} turned explorer (age={mutant.age})")

    def force_diversification(self, patterns, field, t):
        alive = [p for p in patterns if p.alive and p.role_type == "normal"]
        if len(alive) < 10: return
        intent_counts = {}
        for p in alive:
            if p.intent: intent_counts[p.intent["type"]] = intent_counts.get(p.intent["type"], 0) + 1
        if not intent_counts: return
        dominant_intent = max(intent_counts, key=intent_counts.get)
        dominant_pct = intent_counts[dominant_intent] / len(alive)
        if dominant_pct > Config.DIVERSIFICATION_THRESHOLD:
            candidates = [p for p in alive if p.intent and p.intent["type"] == dominant_intent]
            num_to_diversify = max(1, len(candidates) // 5)
            for i in range(num_to_diversify):
                idx = int(phi_hash(t, i, 5555) * len(candidates)) % len(candidates)
                p = candidates[idx]
                if dominant_intent == "explore": new_type = "cooperate"
                elif dominant_intent == "cooperate": new_type = "explore" if phi_hash(t,i,6666)<0.5 else "seek_help"
                elif dominant_intent == "seek_help": new_type = "explore" if phi_hash(t,i,6666)<0.7 else "cooperate"
                else: new_type = "explore"
                priority = 1.0 + 0.5 * phi_hash(t, i, 7777)
                p.goals = [{"type": new_type, "priority": priority, "target": None, "age": 0, "persistence": 50}]
                p.intent = p.goals[0]; p.intent_commitment = priority; p.last_intent_switch_age = p.age
                p._log_event("forced_diversification", old=dominant_intent, new=new_type, t=t)
                p.emotional_memory['grief'] *= 0.8; p.emotional_memory['gratitude'] *= 0.9
                if i == 0: print(f"[t={t}] DIVERSIFICATION: {num_to_diversify} patterns switched from {dominant_intent} -> {new_type}")

    def apply_global_given_queue(self, patterns, field, t):
        candidates = []
        for p in patterns:
            if not p.alive or p.age < Config.GIVEN_MIN_AGE or p.given_cooldown > 0 or p.confidence >= Config.GIVEN_MAX_CONFIDENCE_FOR_CANDIDATE: continue
            candidates.append((p.cognitive_tension - p.confidence, p))
        if not candidates: return
        candidates.sort(key=lambda x: x[0], reverse=True)
        for i, (_, p) in enumerate(candidates[:Config.GIVEN_GLOBAL_PRIORITY_COUNT]):
            p.apply_given_operator(field, forced=p.cognitive_tension > Config.GIVEN_TENSION_TRIGGER)
            if i == 0 and t % 100 == 0: print(f"[t={t}] GLOBAL GIVEN: Pattern {p.id} got 'Given' (tension={p.cognitive_tension:.3f}, conf={p.confidence:.3f})")

