            if strategy < 0.33: noise_factor = 1.0
            elif strategy < 0.66: noise_factor = 1.0 + np.clip(field[x,y,CH['unknown']],0,0.8)*(1.0-self.unknown_model)
            else: noise_factor = 1.0 + np.clip(field[x,y,CH['unknown']],0,0.8)*1.5
            avg_real += np.clip(field[x,y,:5],-10,10)*noise_factor*crisis_factor; avg_unknown += np.clip(field[x,y,CH['unknown']],0,0.8)
            avg_crisis_mem += np.clip(field[x,y,CH['crisis']],0,1); avg_binding += np.clip(field[x,y,CH['binding']],0,1)
            local_gratitude += field[x,y,CH['signal_gratitude']]; local_grief += field[x,y,CH['signal_grief']]; cell_count += 1
        n = len(self.cells); avg_real /= n; avg_unknown /= n; avg_crisis_mem /= n; avg_binding /= n
        local_gratitude /= cell_count; local_grief /= cell_count; local_gratitude = np.clip(local_gratitude, 0.0, 0.5)
        old_grat = self.emotional_memory['gratitude']; old_grief = self.emotional_memory['grief']
        target_grat = (Config.EMOTIONAL_MEMORY_DECAY*old_grat + (1-Config.EMOTIONAL_MEMORY_DECAY)*local_gratitude)
        target_grief = (Config.EMOTIONAL_MEMORY_DECAY*old_grief + (1-Config.EMOTIONAL_MEMORY_DECAY)*local_grief)
        delta_grat = np.clip(target_grat - old_grat, -Config.EMOTIONAL_CAP_RATE, Config.EMOTIONAL_CAP_RATE)
        delta_grief = np.clip(target_grief - old_grief, -Config.EMOTIONAL_CAP_RATE, Config.EMOTIONAL_CAP_RATE)
        self.emotional_memory['gratitude'] = np.clip(old_grat + delta_grat, 0.0, 1.0); self.emotional_memory['grief'] = np.clip(old_grief + delta_grief, 0.0, 1.0)
        _safe_emotional_decay(self.emotional_memory, 'gratitude', self.age); _safe_emotional_decay(self.emotional_memory, 'grief', self.age)
        if self.intent and self.intent["type"] == "explore" and self.role_type != "disorganizer": self.emotional_memory['grief'] *= Config.EXPLORE_GRIEF_REDUCTION
        self._process_incoming_signals(field)
        neighbor_gratitude = 0.0; neighbor_grief = 0.0; neighbor_count = 0
        for (x,y) in self.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%Config.WORLD_SIZE, (y+dy)%Config.WORLD_SIZE; owner = field[nx, ny, CH['owner']]
                if owner != 0 and owner != self.id: neighbor_gratitude += field[nx, ny, CH['signal_gratitude']]; neighbor_grief += field[nx, ny, CH['signal_grief']]; neighbor_count += 1
        if neighbor_count > 0:
            neighbor_gratitude /= neighbor_count; neighbor_grief /= neighbor_count
            emotional_divergence = (abs(self.emotional_memory['gratitude']-neighbor_gratitude) + abs(self.emotional_memory['grief']-neighbor_grief))
            step = self.age
            if (self.age >= Config.SPEACIATION_MIN_AGE and emotional_divergence > Config.EMOTIONAL_SPECIATION_THRESHOLD and phi_hash(self.id, step, 888) < Config.EMOTIONAL_SPECIATION_PROB and (step - self.last_speciation_age) > Config.SPEACIATION_COOLDOWN):
                old_lineage = self.lineage_id; self.lineage_id = self.id + 1_000_000; self.last_speciation_age = step
                self._log_event("speciation", old_lineage=old_lineage, new_lineage=self.lineage_id)
                print(f"[t={step}] EMOTIONAL SPECIATION: Pattern {self.id} lineage {old_lineage} -> {self.lineage_id}")
