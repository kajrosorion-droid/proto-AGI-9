    def update_resonance(self, field):
        if self.in_scream: self.alarm_level = min(1.0, self.alarm_level + 0.3)
        neighbor_alarm = 0.0; weight_sum = 0.0
        for (x,y) in self.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%Config.WORLD_SIZE, (y+dy)%Config.WORLD_SIZE
                owner = field[nx, ny, CH['owner']]
                if owner != 0 and owner != self.id:
                    w = Config.PHI ** (-1); neighbor_alarm += field[nx, ny, CH['resonance']] * w; weight_sum += w
        if weight_sum > 0:
