        if self.local_phase == "DREAM": self.update_dream(field); self.pred_error = max(self.pred_error*Config.METRIC_DECAY, Config.MIN_ACTIVE); return
        if self.local_phase == "SILENCE" and phi_hash(self.id, self.age, 6000) < 0.01:
            drift = np.array([phi_hash(self.id, self.age, 7000+i) for i in range(5)]); self.belief = self.belief*0.98 + 0.04*drift
        avg_real = np.zeros(5); avg_unknown = 0.0; avg_crisis_mem = 0.0; avg_binding = 0.0; local_gratitude = 0.0; local_grief = 0.0; cell_count = 0
        for (x,y) in self.cells:
