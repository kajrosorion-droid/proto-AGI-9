                self.dream_interval = int(phi_hash(self.id, self.age, 888)*40 + 40)
                self._log_event("dream_exit", scar_dream=round(self.scar_dream,4))
                if self.soul_weight > 0.6 and self.coherence > 0.9 and phi_hash(self.id, self.age, 999) < 0.2: self.pending_spore = self.emit_spore(field)
